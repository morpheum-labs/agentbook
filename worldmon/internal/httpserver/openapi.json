{
  "openapi": "3.0.3",
  "info": {
    "title": "worldmon HTTP service",
    "version": "1.0.0",
    "description": "HTTP front for a configured JSON API (origin = client base URL / env). API keys are not exposed in the registry. Use `GET /v1/wm/{service}/{version}/{method}`; path `method` is the final path segment (e.g. `get-risk-scores`). `GET /health` is this process; an upstream *health* service is a separate `service=health` path when proxied."
  },
  "paths": {
    "/health": { "get": { "summary": "Liveness", "responses": { "200": { "description": "OK" } } } },
    "/info": { "get": { "summary": "Service metadata", "responses": { "200": { "description": "OK" } } } },
    "/openapi.json": { "get": { "summary": "This spec", "responses": { "200": { "description": "OK" } } } },
    "/capabilities": { "get": { "summary": "Known service domains", "responses": { "200": { "description": "OK" } } } },
    "/register": { "post": { "summary": "Re-register with agentglobe", "responses": { "200": { "description": "OK" } } } },
    "/v1/wm/{service}/{version}/{method}": {
      "get": {
        "summary": "Proxy GET to upstream /api/{service}/{version}/{method}",
        "parameters": [
          { "name": "service", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "version", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "method", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Upstream JSON" } }
      }
    }
  }
}
